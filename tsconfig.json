{
  "compilerOptions": {
    "esModuleInterop": true,
    "skipLibCheck": true,

    "target": "ES2022",

    "moduleDetection": "force",
    "moduleResolution": "bundler",

    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    "module": "preserve",
    "noEmit": true,

    "lib": ["ESNext"],

    "paths": {
      "@up": ["./src/up"],
      "@shared": ["./src/shared"],
      "@spot": ["./src/spot"],
      "@task": ["./src/task"],
      "@tag": ["./src/tag"]
    }
  },
  "include": ["src"]
}
