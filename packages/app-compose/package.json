{
  "name": "@grlt-hub/app-compose",
  "version": "3.0.0-beta.0",
  "private": false,
  "description": "App-Compose is a TypeScript library that structures your frontend app around isolated tasks, explicit context, and predictable startup — by design.",
  "keywords": [
    "app-compose",
    "dependency-injection",
    "di",
    "grlt",
    "grlt-hub",
    "inversion-of-control",
    "ioc",
    "modular",
    "typescript"
  ],
  "homepage": "https://app-compose.dev",
  "license": "MIT",
  "contributors": [
    {
      "name": "Mikhail Kireev",
      "url": "https://github.com/kireevmp"
    },
    {
      "name": "Viktor Pasynok",
      "url": "https://github.com/binjospookie"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grlt-hub/app-compose.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && tsc --noEmit -p tsconfig.json",
    "dev": "tsdown --watch",
    "prepack": "pnpm build",
    "bench": "vitest bench",
    "test": "vitest run",
    "lint": "knip && oxlint ./src"
  },
  "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a"
}
