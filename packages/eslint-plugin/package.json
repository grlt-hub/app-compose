{
  "name": "@app-compose/eslint-plugin",
  "version": "3.0.0-beta.8",
  "private": false,
  "description": "Enforcing best practices for @app-compose",
  "keywords": [
    "app-compose",
    "eslint",
    "eslint-plugin",
    "eslintplugin",
    "grlt",
    "grlt-hub"
  ],
  "homepage": "https://app-compose.dev",
  "license": "MIT",
  "contributors": [
    {
      "name": "Mikhail Kireev",
      "url": "https://github.com/kireevmp"
    },
    {
      "name": "Viktor Pasynok",
      "url": "https://github.com/binjospookie"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grlt-hub/app-compose.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json && tsdown",
    "dev": "tsdown --watch",
    "prepack": "pnpm build",
    "test": "vitest run",
    "lint": "knip && oxlint ./src"
  },
  "dependencies": {
    "@typescript-eslint/type-utils": "^8.58.0",
    "@typescript-eslint/utils": "^8.58.0",
    "esquery": "^1"
  },
  "devDependencies": {
    "@app-compose/coda": "workspace:*",
    "@app-compose/core": "workspace:*",
    "@types/esquery": "^1.5.4",
    "@typescript-eslint/rule-tester": "8.61.0",
    "eslint": "^10.4.1"
  },
  "peerDependencies": {
    "eslint": "^9.0.0 || ^10.0.0",
    "typescript": "^5.0.0 || ^6.0.0"
  },
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed"
}
