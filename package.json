{
  "name": "@grlt-hub/app-compose",
  "version": "3.0.0-alpha.5",
  "keywords": [
    "grlt",
    "grlt-hub",
    "app-compose",
    "dependency-injection",
    "di",
    "inversion-of-control",
    "ioc",
    "modular",
    "typescript"
  ],
  "homepage": "https://grlt-hub.github.io/app-compose/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grlt-hub/app-compose.git"
  },
  "license": "MIT",
  "contributors": [
    {
      "name": "Mikhail Kireev",
      "url": "https://github.com/kireevmp"
    },
    {
      "name": "Viktor Pasynok",
      "url": "https://github.com/binjospookie"
    }
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepack": "pnpm build",
    "test": "vitest run",
    "lint": "knip && oxlint ./src"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "@types/node": "25.0.3",
    "@vitest/coverage-v8": "4.0.16",
    "knip": "5.75.2",
    "oxlint": "1.34.0",
    "prettier-plugin-organize-imports": "4.3.0",
    "tsdown": "0.18.1",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  },
  "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a"
}
