{
  "name": "composer",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "test": "vitest run"
  },
  "devDependencies": {
    "@rslib/core": "0.18.1",
    "@types/node": "24.10.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "4.0.13"
  }
}
